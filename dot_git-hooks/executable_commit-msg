#!/bin/sh

msg_file=$1

[ -n "$msg_file" ] && [ -f "$msg_file" ] || exit 0

git_dir=$(git rev-parse --git-dir 2>/dev/null)
if [ -n "$git_dir" ]; then
  local_hook="$git_dir/hooks/commit-msg"
  this_hook=$(cd "$(dirname "$0")" 2>/dev/null && pwd -P)/$(basename "$0")
  repo_hook=$(cd "$(dirname "$local_hook")" 2>/dev/null && pwd -P)/$(basename "$local_hook")

  if [ -x "$local_hook" ] && [ "$repo_hook" != "$this_hook" ]; then
    "$local_hook" "$@"
    status=$?
    [ "$status" -eq 0 ] || exit "$status"
  fi
fi

tmp_file="${msg_file}.no-co-authored-by.$$"

awk '
{
  lower = tolower($0)
  if (lower ~ /^[[:space:]]*co-authored-by:[[:space:]]*/) {
    next
  }
  print
}
' "$msg_file" > "$tmp_file" && mv "$tmp_file" "$msg_file"

status=$?
[ "$status" -eq 0 ] || rm -f "$tmp_file"
exit "$status"
