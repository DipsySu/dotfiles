# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zprofile.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zprofile.pre.zsh"

# NOTE: do NOT source ~/.zshrc here.
# zsh automatically sources .zshrc for every interactive shell, including
# login+interactive shells launched by Terminal.app, iTerm2, and VS Code.
# Sourcing it manually makes the shell init twice and slows down startup.

