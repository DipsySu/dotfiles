# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"

# Amazon Q pre block. Keep near the top when installed.
[[ -f "${HOME}/.local/share/amazon-q/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/.local/share/amazon-q/shell/zshrc.pre.zsh"

# PATH
typeset -U path
path=("$HOME/.local/bin" $path)

for _tool_bin in \
    "$HOME/.antigravity/antigravity/bin" \
    "$HOME/.codeium/windsurf/bin" \
    "$HOME/google-cloud-sdk/bin"
do
    [[ -d "$_tool_bin" ]] && path=("$_tool_bin" $path)
done
unset _tool_bin

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew: Apple Silicon uses /opt/homebrew, Intel uses /usr/local.
for _brew in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$_brew" ]]; then
        eval "$("$_brew" shellenv)"
        break
    fi
done
unset _brew
{{ else if eq .chezmoi.os "linux" -}}
# Homebrew on Linux / WSL.
for _brew in /home/linuxbrew/.linuxbrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$_brew" ]]; then
        eval "$("$_brew" shellenv)"
        break
    fi
done
unset _brew

if command -v explorer.exe >/dev/null 2>&1; then
    alias open="explorer.exe"
fi
{{ end -}}

# Zinit. Prefer Homebrew's zinit, fall back to ~/.local/share/zinit.
_zinit_script=""
if [[ -n "$HOMEBREW_PREFIX" && -r "$HOMEBREW_PREFIX/opt/zinit/zinit.zsh" ]]; then
    _zinit_script="$HOMEBREW_PREFIX/opt/zinit/zinit.zsh"
elif [[ -r "${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git/zinit.zsh" ]]; then
    _zinit_script="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git/zinit.zsh"
elif command -v git >/dev/null 2>&1; then
    _zinit_home="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
    mkdir -p "${_zinit_home:h}"
    git clone --depth=1 https://github.com/zdharma-continuum/zinit.git "$_zinit_home" >/dev/null 2>&1 && _zinit_script="$_zinit_home/zinit.zsh"
    unset _zinit_home
fi

if [[ -n "$_zinit_script" ]]; then
    source "$_zinit_script"

    # Load syntax highlighting synchronously. This avoids repeated ZLE widget
    # wrapping with tools such as Kiro CLI autosuggestions.
    zinit ice atinit"zicompinit; zicdreplay"
    zinit light zdharma-continuum/fast-syntax-highlighting

    zinit wait lucid light-mode for \
        blockf atpull"zinit creinstall -q ." \
            zsh-users/zsh-completions

    # OMZ git plugin only; do not load all of Oh My Zsh.
    zinit wait lucid for OMZP::git
fi
unset _zinit_script

{{- if .shell.enable_starship }}
# Starship prompt
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi
{{- end }}

# Mise: Node / Java / Go / Python / Flutter and npm CLIs are managed here.
if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate zsh)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
    eval "$("$HOME/.local/bin/mise" activate zsh)"
fi

# fzf
if command -v fzf >/dev/null 2>&1; then
    source <(fzf --zsh)
    if command -v fd >/dev/null 2>&1; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
        export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
    fi
    export FZF_DEFAULT_OPTS='--height 60% --layout=reverse --border --info=inline'
    if command -v bat >/dev/null 2>&1; then
        export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
    fi
    if command -v eza >/dev/null 2>&1; then
        export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always --icons {} | head -50'"
    fi
fi

# direnv
if command -v direnv >/dev/null 2>&1; then
    eval "$(direnv hook zsh)"
fi

{{- if .shell.enable_zoxide }}
# Zoxide
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
    alias cd="z"
fi
{{- end }}

{{- if .shell.enable_eza }}
# Eza aliases
if command -v eza >/dev/null 2>&1; then
    unalias ls ll la lt 2>/dev/null
    alias ls='eza --icons --group-directories-first'
    alias ll='eza -lh --icons --group-directories-first'
    alias la='eza -a --icons --group-directories-first'
    alias lt='eza --tree --icons'
fi
{{- end }}

# bat: keep cat untouched for scripts and pipes.
if command -v bat >/dev/null 2>&1; then
    alias bcat='bat'
fi

# History
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS HIST_SAVE_NO_DUPS SHARE_HISTORY \
       HIST_REDUCE_BLANKS HIST_VERIFY EXTENDED_HISTORY HIST_IGNORE_SPACE

# User modules
[[ -f ~/.zsh_functions ]] && source ~/.zsh_functions
[[ -f ~/.zsh_aliases ]] && source ~/.zsh_aliases
for _f in ~/.zsh/*.zsh(N); do source "$_f"; done
unset _f

# Google Cloud SDK completion, when installed outside Homebrew.
[[ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]] && source "$HOME/google-cloud-sdk/path.zsh.inc"
[[ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]] && source "$HOME/google-cloud-sdk/completion.zsh.inc"

# Amazon Q post block.
[[ -f "${HOME}/.local/share/amazon-q/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/.local/share/amazon-q/shell/zshrc.post.zsh"

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh"
