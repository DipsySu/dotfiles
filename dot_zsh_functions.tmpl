# --- 辅助函数：打印凭证 (带颜色高亮) ---
function print_aws_creds() {
    echo ""
    echo -e "\033[0;33m🔑 Current Session Credentials:\033[0m"
    echo "---------------------------------------------------"
    echo -e "AWS_ACCESS_KEY_ID     : \033[0;32m$AWS_ACCESS_KEY_ID\033[0m"
    if [ -n "$AWS_SECRET_ACCESS_KEY" ]; then
        echo -e "AWS_SECRET_ACCESS_KEY : \033[0;32m<redacted>\033[0m"
    fi
    # 如果有 Session Token 也打印出来，没有就不打印
    if [ -n "$AWS_SESSION_TOKEN" ]; then
        echo -e "AWS_SESSION_TOKEN     : \033[0;32m$AWS_SESSION_TOKEN\033[0m"
    fi
    echo "---------------------------------------------------"
}

function aws-cn() {
    if ! aws sts get-caller-identity --profile aws-cn > /dev/null 2>&1; then
        echo "⚠️  SSO Token expired. Launching browser login..."
        aws sso login --profile aws-cn
    fi

    export AWS_REGION="{{ .aws.cn_region }}"
    export AWS_DEFAULT_REGION="{{ .aws.cn_region }}"
    export AWS_PROFILE="aws-cn"

    echo "✅ Switched to aws-cn environment!"
    
    # 导出环境变量
    eval $(aws configure export-credentials --profile aws-cn --format env)
    # 打印凭证
    print_aws_creds
}

function aws-sg() {
    export AWS_REGION="{{ .aws.sg_region }}"
    export AWS_PROFILE="aws-sg"
    
    if [ ! -d "$HOME/.aws-sg" ]; then
        mkdir -p "$HOME/.aws-sg"
    fi
    export USER_HOME="$HOME/.aws-sg"

    echo "Fetching CodeArtifact token..."
    export CODEARTIFACT_AUTH_TOKEN=$(aws --profile aws-sg codeartifact get-authorization-token --domain {{ .aws.codeartifact_domain }} --query authorizationToken --output text)
    
    echo "✅ Switched to aws-sg environment!"

    # 导出环境变量
    eval $(aws configure export-credentials --profile aws-sg --format env)
    # 打印凭证
    print_aws_creds
}

# --- 家居自动化脚本开始 ---

# Tailscale CLI path. Leave home.tailscale_path empty to auto-detect across
# WSL, macOS Intel, and Apple Silicon machines.
{{- if .home.tailscale_path }}
export TAILSCALE_EXE="{{ .home.tailscale_path }}"
{{- else }}
for ts_path in \
    "/Applications/Tailscale.app/Contents/MacOS/Tailscale" \
    "/mnt/c/Program Files/Tailscale/tailscale.exe" \
    "/opt/homebrew/bin/tailscale" \
    "/usr/local/bin/tailscale" \
    "/usr/bin/tailscale"
do
    if [ -f "$ts_path" ]; then
        export TAILSCALE_EXE="$ts_path"
        break
    fi
done
{{- end }}

# 内部私有函数：检查并确保 Tailscale 已连接
_ensure_tailscale() {
    echo "--- 检查 Tailscale 状态 ---"

    if [ -z "$TAILSCALE_EXE" ] || [ ! -x "$TAILSCALE_EXE" ]; then
        echo "❌ [Error] 未找到 Tailscale CLI。"
        return 1
    fi
    
    # 1. 检查 tailscale.exe 是否能联通后台
    local status_output=$("$TAILSCALE_EXE" status 2>&1)
    
    if echo "$status_output" | grep -q "Tailscale is starting"; then
        echo "⏳ Tailscale 正在启动中，请稍候..."
        sleep 3
    fi

    # 2. 如果状态依然是 NoState 或 NeedsLogin，说明需要 Windows 端干预
    if echo "$status_output" | grep -q "NoState\|Stopped"; then
        echo "❌ [Error] Windows 端的 Tailscale 未启动或已退出。"
        echo "💡 请手动点击 Windows 任务栏右下角的 Tailscale 图标进行 Connect。"
        return 1
    fi

    echo "✅ [Connected] Tailscale 隧道就绪。"
    return 0
}

# 1. 唤醒命令
wake_home() {
    echo "--- 远程唤醒流程开始 [$(date '+%H:%M:%S')] ---"
    
    # 1. 检查网络
    if _ensure_tailscale; then
        echo "   [$(date '+%H:%M:%S')] 🔗 网络就绪，准备发起 SSH 请求..."
        
        # 2. 执行唤醒 (增加 -q 减少无用提示，增加 -t 强制分配终端以实时回显)
        # 注意：这里我们直接调用 ssh，它会实时显示远程脚本里的 echo 内容
        ssh -t {{ .home.ssh_host }} "/root/wake_pc.sh"
        
        # 3. 唤醒后的自动检测 (新增功能：自动帮你 Ping)
        echo "   [$(date '+%H:%M:%S')] ⏱️ 脚本执行完毕，开始持续探测电脑状态..."
        echo "   (按 Ctrl+C 可以提前结束探测)"
        
        # 尝试 Ping 你的电脑 IP，成功则退出
        # 逻辑：在 iStoreOS 上代为 ping 电脑
        ssh {{ .home.ssh_host }} "ping -c 10 -i 1 {{ .home.pc_ip }}" | grep --line-buffered "from"
        
        echo "--- 唤醒流程结束 [$(date '+%H:%M:%S')] ---"
    fi
}

# 2. 纯 SSH 命令
ssh_istore() {
    if _ensure_tailscale; then
        echo "正在连接 iStoreOS 终端..."
        ssh {{ .home.ssh_host }}
    fi
}

sleep_home() {
    echo "--- 远程休眠流程开始 [$(date '+%H:%M:%S')] ---"
    # 内部检查 Tailscale 是否已由你手动开启
    if _ensure_tailscale; then
        echo "   [$(date '+%H:%M:%S')] 🔗 正在通过 iStoreOS 下达休眠指令..."
        ssh -t {{ .home.ssh_host }} "/root/sleep_pc.sh"
        echo "--- 流程结束 ---"
    fi
}

# 查看家中心 PC 的实时硬件状态
check_home() {
    # 确保网络连接
    if _ensure_tailscale; then
        echo "📊 正在从 iStoreOS 抓取 PC 实时数据..."
        # 使用 -t 保持彩色输出，-q 隐藏 SSH 登录提示
        ssh -t {{ .home.ssh_host }} "/root/check_pc.sh"
    fi
}

# --- 家居自动化脚本结束 ---

# =================================================================
# macOS 系统诊断函数
# =================================================================

# 综合系统状态检查
mac_check() {
    echo ""
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;36m📊 macOS 系统状态综合诊断\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    # 系统信息（system_profiler 调用贵，只调一次缓存）
    local _hw=$(system_profiler SPHardwareDataType 2>/dev/null)
    echo -e "\033[1;33m🖥️  系统基本信息\033[0m"
    echo "   机型: $(echo "$_hw" | grep "Model Name" | sed 's/.*Model Name: //')"
    echo "   芯片: $(echo "$_hw" | grep "Chip\|Processor Name" | head -1 | sed 's/.*: //')"
    echo "   内存: $(echo "$_hw" | grep "Memory:" | sed 's/.*Memory: //')"
    echo "   启动时间: $(uptime | sed 's/.*up *//;s/,.*user.*//;s/ *//')"
    # 系统负载（1分钟、5分钟、15分钟平均值）
    local load=$(uptime | awk -F'load averages:' '{print $2}' | sed 's/^ *//')
    echo "   系统负载: $load (1分钟 / 5分钟 / 15分钟)"
    echo ""

    # 磁盘空间
    echo -e "\033[1;33m💾 磁盘空间 (启动磁盘)\033[0m"
    # 动态读取物理磁盘容量（避免硬编码）
    local disk_phys_size=$(diskutil info / 2>/dev/null | awk -F': *' '/Disk Size/ {print $2; exit}' | awk '{print $1, $2}')
    [[ -z "$disk_phys_size" ]] && disk_phys_size="N/A"
    df -h / | awk -v phys="$disk_phys_size" 'NR==2 {
        size=$2
        used=$3
        avail=$4
        percent=$5
        gsub(/%/, "", percent)
        printf "   物理容量: %s (分区显示: %s) | 已用: %s | 可用: %s | 使用率: %s\n", phys, size, used, avail, percent"%"
        if (percent > 90) printf "   \033[1;31m⚠️  磁盘空间不足！\033[0m\n"
        else if (percent > 80) printf "   \033[1;33m⚠️  磁盘空间紧张\033[0m\n"
        else printf "   \033[1;32m✅ 磁盘空间充足\033[0m\n"
    }'
    echo ""

    # 内存压力 - 更友好的显示
    echo -e "\033[1;33m🧠 内存状态\033[0m"

    # 获取内存详细信息
    local vm_stats=$(vm_stat)
    # 页面大小通常是 4096 字节
    local page_size=4096

    # 解析 vm_stat 输出（注意：数字后面有 . 点号）
    local pages_free=$(echo "$vm_stats" | grep "Pages free" | awk '{print $3}' | sed 's/\.//')
    local pages_active=$(echo "$vm_stats" | grep "Pages active" | awk '{print $3}' | sed 's/\.//')
    local pages_inactive=$(echo "$vm_stats" | grep "Pages inactive" | awk '{print $3}' | sed 's/\.//')
    local pages_wired=$(echo "$vm_stats" | grep "Pages wired" | awk '{print $4}' | sed 's/\.//')
    local pages_compressor=$(echo "$vm_stats" | grep "Pages occupied by compressor" | awk '{print $5}' | sed 's/\.//')

    # 转换为 GB (1 GB = 1024*1024*1024 bytes)
    local total_mem_gb=$(sysctl -n hw.memsize | awk '{printf "%.1f", $1 / 1073741824}')
    local free_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${pages_free} * ${page_size} / 1073741824}")
    local active_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${pages_active} * ${page_size} / 1073741824}")
    local inactive_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${pages_inactive} * ${page_size} / 1073741824}")
    local wired_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${pages_wired} * ${page_size} / 1073741824}")
    local compressor_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${pages_compressor} * ${page_size} / 1073741824}")

    # 计算已用内存 (active + inactive + wired + compressor)
    local used_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${active_mem_gb} + ${inactive_mem_gb} + ${wired_mem_gb} + ${compressor_mem_gb}}")
    local free_percent=$(awk "BEGIN {printf \"%.0f\", ${pages_free} / ($(sysctl -n hw.memsize) / ${page_size}) * 100}")
    local used_percent=$(awk "BEGIN {printf \"%.0f\", 100 - ${free_percent}}")

    # 获取内存压力状态
    local mem_pressure_status=$(memory_pressure | grep "System-wide memory free percentage" | sed 's/.*: //' | sed 's/%$//')
    local mem_pressure_label="正常"
    local mem_pressure_color="\033[1;32m"
    if [ "$mem_pressure_status" -lt 15 ]; then
        mem_pressure_label="严重不足"
        mem_pressure_color="\033[1;31m"
    elif [ "$mem_pressure_status" -lt 30 ]; then
        mem_pressure_label="紧张"
        mem_pressure_color="\033[1;33m"
    fi

    # 内存状态颜色和图标
    local mem_color="\033[1;32m"
    local mem_icon="✅"
    if [ "$used_percent" -gt 85 ]; then
        mem_color="\033[1;31m"
        mem_icon="⚠️ "
    elif [ "$used_percent" -gt 70 ]; then
        mem_color="\033[1;33m"
        mem_icon="⚠️ "
    fi

    printf "   总容量: %.1f GB | 已用: %.1f GB | 使用率: ${mem_color}%.0f%%\033[0m ${mem_icon}\n" "$total_mem_gb" "$used_mem_gb" "$used_percent"
    echo "   活跃: ${active_mem_gb} GB | 非活跃: ${inactive_mem_gb} GB | 有线: ${wired_mem_gb} GB | 压缩: ${compressor_mem_gb} GB"
    echo "   系统内存压力: ${mem_pressure_color}${mem_pressure_label}\033[0m (空闲 ${mem_pressure_status}%)"
    echo ""

    # CPU 占用最高的进程
    echo -e "\033[1;33m🔥 CPU 占用最高的 5 个进程\033[0m"
    ps aux | sort -rk 3 | head -6 | awk 'NR==1 {print "   PID    %CPU   %MEM   PROCESS"} NR>1 {printf "   %-6s %-5s %-5s %s\n", $2, $3, $4, $11}'
    echo ""

    # 内存占用最高的进程
    echo -e "\033[1;33m💧 内存占用最高的 5 个进程\033[0m"
    ps aux | sort -rk 4 | head -6 | awk 'NR==1 {print "   PID    %CPU   %MEM   PROCESS"} NR>1 {printf "   %-6s %-5s %-5s %s\n", $2, $3, $4, $11}'
    echo ""

    # Docker 检查（如果安装）
    if command -v docker &> /dev/null; then
        echo -e "\033[1;33m🐳 Docker 状态\033[0m"
        if docker info &> /dev/null; then
            echo "   运行中的容器: $(docker ps -q | wc -l | tr -d ' ')"
            echo "   总容器数: $(docker ps -aq | wc -l | tr -d ' ')"
            echo "   Docker 镜像数: $(docker images -q | wc -l | tr -d ' ')"

            # Docker 容器资源占用
            echo ""
            echo "   Docker 容器资源占用:"
            docker stats --no-stream --format "table   {{ "{{" }}.Name{{ "}}" }}\t{{ "{{" }}.CPUPerc{{ "}}" }}\t{{ "{{" }}.MemUsage{{ "}}" }}" 2>/dev/null | head -6
        else
            echo "   \033[1;31m❌ Docker 未运行\033[0m"
        fi
        echo ""
    fi

    # Swap 使用情况
    echo -e "\033[1;33m📄 Swap 使用情况\033[0m"
    local swap_used=$(vm_stat | grep "Pages swapped out" | sed 's/.*: *//')
    if [ -n "$swap_used" ] && [ "$swap_used" != "0" ]; then
        echo "   已换出页面: $swap_used"
        echo "   \033[1;33m⚠️  系统正在使用 Swap，可能存在内存压力\033[0m"
    else
        echo "   \033[1;32m✅ Swap 使用正常\033[0m"
    fi
    echo ""

    # kernel_task 检查（散热问题）
    echo -e "\033[1;33m🌡️  散热检查 (kernel_task)\033[0m"
    local kernel_cpu=$(ps aux | grep '[k]ernel_task' | awk '{sum+=$3} END {print sum}')
    if [ ! -z "$kernel_cpu" ] && [ $(echo "$kernel_cpu > 100" | bc -l 2>/dev/null || echo 0) -eq 1 ]; then
        echo "   kernel_task CPU 占用: ${kernel_cpu}%"
        echo "   \033[1;31m⚠️  系统可能过热，建议检查散热或清理灰尘\033[0m"
    else
        echo "   \033[1;32m✅ 散热状态正常\033[0m"
    fi
    echo ""

    # 建议
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;36m💡 快速修复建议\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo "   mac_purge    - 清理内存缓存"
    echo "   mac_clean    - 清理系统缓存"
    echo "   mac_docker   - Docker 诊断和清理"
    echo "   mac_cpu      - CPU 详细分析"
    echo "   mac_mem      - 内存详细分析"
    echo ""
}

# CPU 详细分析
mac_cpu() {
    echo ""
    echo -e "\033[1;36m🔥 CPU 详细分析\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    echo -e "\033[1;33mCPU 信息\033[0m"
    echo "   核心数: $(sysctl -n hw.ncpu)"
    echo "   物理 CPU: $(sysctl -n hw.physicalcpu)"
    echo "   逻辑 CPU: $(sysctl -n hw.logicalcpu)"
    echo ""

    echo -e "\033[1;33m当前 CPU 占用 (按 q 退出)\033[0m"
    top -u -o cpu -l 1 | head -20
    echo ""

    echo -e "\033[1;33m所有用户的 CPU 占用\033[0m"
    ps aux | awk '{cpu[$1]+=$3} END {for (i in cpu) if (cpu[i]>0.1) printf "   %-15s %.1f%%\n", i, cpu[i]}' | sort -rk 2
    echo ""
}

# 内存详细分析
mac_mem() {
    echo ""
    echo -e "\033[1;36m💧 内存详细分析\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    echo -e "\033[1;33m虚拟内存统计\033[0m"
    vm_stat | sed 's/://g' | awk '{printf "   %-20s %s\n", $1, $2}'
    echo ""

    echo -e "\033[1;33m内存压力详情\033[0m"
    memory_pressure
    echo ""

    echo -e "\033[1;33m内存占用最高的 15 个进程\033[0m"
    ps aux | sort -rk 4 | head -16 | awk 'NR==1 {print "   PID    %CPU   %MEM   RSS(kB)   PROCESS"} NR>1 {printf "   %-6s %-5s %-5s %-8s %s\n", $2, $3, $4, $6/1024, $11}'
    echo ""

    # 检查是否有内存泄漏嫌疑的进程
    echo -e "\033[1;33m可能存在内存泄漏的进程 (高内存占用但低 CPU)\033[0m"
    ps aux | awk '$3 < 5 && $4 > 2 {printf "   %-6s %-5s %-5s %s\n", $2, $3, $4, $11}' | head -10
    echo ""
}

# Docker 诊断和清理
mac_docker() {
    echo ""
    echo -e "\033[1;36m🐳 Docker 诊断\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    if ! command -v docker &> /dev/null; then
        echo "   \033[1;31m❌ Docker 未安装\033[0m"
        return 1
    fi

    if ! docker info &> /dev/null; then
        echo "   \033[1;31m❌ Docker 未运行\033[0m"
        echo "   💡 尝试启动 Docker Desktop"
        return 1
    fi

    echo -e "\033[1;33mDocker 系统信息\033[0m"
    docker info | grep -E "Server Version|Operating System|CPUs|Total Memory|Docker Root Dir"
    echo ""

    echo -e "\033[1;33m运行中的容器\033[0m"
    docker ps --format "   {{ "{{" }}.ID{{ "}}" }}\t{{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}\t{{ "{{" }}.Image{{ "}}" }}"
    echo ""

    echo -e "\033[1;33m容器资源占用 (实时)\033[0m"
    docker stats --no-stream --format "   table {{ "{{" }}.Name{{ "}}" }}\t{{ "{{" }}.CPUPerc{{ "}}" }}\t{{ "{{" }}.MemUsage{{ "}}" }}\t{{ "{{" }}.NetIO{{ "}}" }}\t{{ "{{" }}.BlockIO{{ "}}" }}"
    echo ""

    echo -e "\033[1;33mDocker 磁盘使用情况\033[0m"
    docker system df
    echo ""

    # 检查是否有僵尸容器或大量未使用的镜像
    local zombie_containers=$(docker ps -a -q -f status=exited -f status=created | wc -l | tr -d ' ')
    local dangling_images=$(docker images -qf dangling=true | wc -l | tr -d ' ')

    echo -e "\033[1;33m清理建议\033[0m"
    if [ "$zombie_containers" -gt 0 ]; then
        echo "   发现 $zombie_containers 个已停止的容器"
        echo "   清理命令: docker container prune -f"
    fi

    if [ "$dangling_images" -gt 0 ]; then
        echo "   发现 $dangling_images 个悬空镜像"
        echo "   清理命令: docker image prune -f"
    fi

    if [ "$zombie_containers" -eq 0 ] && [ "$dangling_images" -eq 0 ]; then
        echo "   \033[1;32m✅ Docker 环境干净\033[0m"
    fi
    echo ""

    echo -e "\033[1;33m💡 Docker 维护命令\033[0m"
    echo "   docker system prune -a          - 清理所有未使用的数据"
    echo "   docker system prune -a --volumes - 清理包括卷在内的所有数据"
    echo "   docker restart $(docker ps -q)   - 重启所有运行中的容器"
    echo ""
}

# 清理内存缓存
mac_purge() {
    echo ""
    echo -e "\033[1;36m🧹 清理内存缓存\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    # purge 需要 root；sudo 会自动提示密码。
    sudo purge

    echo ""
    echo -e "\033[1;32m✅ 内存缓存已清理\033[0m"
    echo ""

    # 显示清理后的内存状态
    memory_pressure
    echo ""
}

# 清理系统缓存
mac_clean() {
    echo ""
    echo -e "\033[1;36m🧹 清理系统缓存\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    echo -e "\033[1;33m清理用户缓存\033[0m"
    rm -rf ~/Library/Caches/* 2>/dev/null && echo "   ✅ 用户缓存已清理" || echo "   ⚠️  部分缓存清理失败"
    echo ""

    echo -e "\033[1;33m清理系统日志 (需要管理员权限)\033[0m"
    sudo rm -rf /Library/Logs/* 2>/dev/null && echo "   ✅ 系统日志已清理" || echo "   ⚠️  日志清理失败"
    echo ""

    echo -e "\033[1;33m清理诊断报告\033[0m"
    sudo rm -rf /Library/Logs/DiagnosticReports/* 2>/dev/null && echo "   ✅ 诊断报告已清理" || echo "   ⚠️  诊断报告清理失败"
    echo ""

    echo -e "\033[1;33m清理 Time Machine 本地快照\033[0m"
    local snapshots=$(tmutil listlocalsnapshots / 2>/dev/null | grep -v "No local snapshots" | wc -l | tr -d ' ')
    if [ "$snapshots" -gt 0 ]; then
        tmutil deletelocalsnapshots / 2>/dev/null && echo "   ✅ Time Machine 快照已清理 ($snapshots 个)" || echo "   ⚠️  Time Machine 快照清理失败"
    else
        echo "   ℹ️  没有需要清理的 Time Machine 快照"
    fi
    echo ""

    echo -e "\033[1;33m清理 Docker (如果已安装)\033[0m"
    if command -v docker &> /dev/null && docker info &> /dev/null; then
        echo "   清理 Docker 未使用的镜像和容器..."
        docker system prune -f --volumes 2>/dev/null && echo "   ✅ Docker 清理完成" || echo "   ⚠️  Docker 清理失败"
    fi
    echo ""

    echo -e "\033[1;32m✅ 系统缓存清理完成\033[0m"
    echo ""

    # 显示清理后的磁盘空间
    echo -e "\033[1;33m当前磁盘空间\033[0m"
    df -h /
    echo ""
}

# 实时监控模式（类似 top 的彩色版本）
mac_monitor() {
    echo ""
    echo -e "\033[1;36m📊 实时系统监控 (按 Ctrl+C 退出)\033[0m"
    echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    while true; do
        clear
        echo -e "\033[1;36m📊 macOS 实时监控 - $(date '+%Y-%m-%d %H:%M:%S')\033[0m"
        echo -e "\033[1;36m$(printf '─%.0s' {1..80})\033[0m"
        echo ""

        # 系统负载
        local load=$(uptime | awk -F'load averages:' '{print $2}')
        echo -e "\033[1;33m系统负载:\033[0m $load"

        # 内存压力
        local mem_status=$(memory_pressure | grep "System-wide memory" | sed 's/.*: //')
        echo -e "\033[1;33m内存状态:\033[0m $mem_status"

        # 磁盘空间
        local disk=$(df -h / | awk 'NR==2 {print $5}')
        echo -e "\033[1;33m磁盘使用:\033[0m $disk"
        echo ""

        # CPU 占用 Top 5
        echo -e "\033[1;33m🔥 CPU Top 5:\033[0m"
        ps aux | sort -rk 3 | head -6 | awk 'NR>1 {printf "   %-5s %-5s %s\n", $3"%", $4"%", $11}'
        echo ""

        # 内存占用 Top 5
        echo -e "\033[1;33m💧 内存 Top 5:\033[0m"
        ps aux | sort -rk 4 | head -6 | awk 'NR>1 {printf "   %-5s %-5s %s\n", $3"%", $4"%", $11}'
        echo ""

        # Docker 状态
        if command -v docker &> /dev/null && docker info &> /dev/null; then
            echo -e "\033[1;33m🐳 Docker 容器:\033[0m"
            docker stats --no-stream --format "   {{ "{{" }}.Name{{ "}}" }} - {{ "{{" }}.CPUPerc{{ "}}" }} - {{ "{{" }}.MemUsage{{ "}}" }}" 2>/dev/null | head -5
        fi

        sleep 3
    done
}

function gpullall() {
    # 并行 pull (同时跑 4 个)，避免 N 个仓库串行等网络
    find . -maxdepth 1 -type d -name '.git' -prune -o -maxdepth 1 -type d -print0 \
        | xargs -0 -I {} -P 4 sh -c '[ -d "{}/.git" ] && echo "⏬  {}" && git -C "{}" pull --ff-only 2>&1 | sed "s/^/    /"'
}
function gscan() {
    echo ""
    # 打印表头
    printf "\033[1;30m%-35s %-25s %s\033[0m\n" "📦 REPOSITORY" "🌿 BRANCH" "📊 STATUS"
    echo "------------------------------------------------------------------------"

    # 遍历当前目录下所有子文件夹
    for d in ./*/; do
        # 只要是 git 仓库
        if [ -d "$d/.git" ]; then
            repo_name=$(basename "$d")

            # 获取当前分支名
            branch=$(git -C "$d" branch --show-current)

            # 获取当前状态 (是否有未提交的修改)
            # --porcelain 输出空字符串表示干净，否则表示有修改
            if [ -z "$(git -C "$d" status --porcelain)" ]; then
                status_icon="✅ Clean"
                status_color="\033[32m" # 绿色
            else
                status_icon="⚠️  Modified"
                status_color="\033[31m" # 红色
            fi

            # 打印格式化的一行
            # %-35s 表示左对齐占35个字符宽度
            printf "\033[1;36m%-35s\033[0m \033[33m%-25s\033[0m ${status_color}%s\033[0m\n" "$repo_name" "$branch" "$status_icon"
        fi
    done
    echo ""
}
